#!/bin/bash
#
# tes3mp-upload-mods — Upload mods to a remote TES3MP server
#
# This script reads the admin configuration from ~/.config/tes3mp/admin.conf,
# syncs the local mods directory to the server, and runs update_mods.sh.
#
# Configuration (~/.config/tes3mp/admin.conf):
# Copy from: https://raw.githubusercontent.com/Saagilat/tes3mp-easy-setup/master/tools/linux/admin/admin.conf
#
# Usage:
#   tes3mp-upload-mods
#
# Dependencies: bash, rsync, ssh

set -euo pipefail

CONFIG_FILE="$HOME/.config/tes3mp/admin.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

err()  { echo -e "${RED}[ERROR]${NC} $*" >&2; }
ok()   { echo -e "${GREEN}[OK]${NC}   $*"; }

# --- Check config ---
if [ ! -f "$CONFIG_FILE" ]; then
    err "Config file not found: $CONFIG_FILE"
    echo ""
    echo "Download the template:"
    echo "  mkdir -p ~/.config/tes3mp"
    echo "  wget -O $CONFIG_FILE \\"
    echo "    https://raw.githubusercontent.com/Saagilat/tes3mp-easy-setup/master/tools/linux/admin/admin.conf"
    echo ""
    echo "Then edit it: nano $CONFIG_FILE"
    exit 1
fi

# --- Source config ---
source "$CONFIG_FILE"

# --- Validate config ---
if [ -z "${SSH_HOST:-}" ]; then
    err "SSH_HOST is not set in $CONFIG_FILE"
    exit 1
fi

if [ -z "${MODS_DIR:-}" ]; then
    err "MODS_DIR is not set in $CONFIG_FILE"
    exit 1
fi

if [ ! -d "$MODS_DIR" ]; then
    err "Mods directory does not exist: $MODS_DIR"
    exit 1
fi

# --- Check dependencies ---
for cmd in rsync ssh; do
    if ! command -v "$cmd" &>/dev/null; then
        err "'$cmd' not found. Install it and try again."
        exit 1
    fi
done

echo "=== TES3MP Mod Upload ==="
echo "  SSH host:  $SSH_HOST"
echo "  Mods dir:  $MODS_DIR"
echo ""

# --- Step 1: Sync mods ---
echo "[1/2] Syncing mods to server..."
rsync -avz --delete "$MODS_DIR"/ "$SSH_HOST":/opt/tes3mp/mods/

ok "Sync complete"

echo ""
echo "[2/2] Running update_mods.sh on server..."
ssh "$SSH_HOST" "cd /opt/tes3mp && bash update_mods.sh"

echo ""
echo "=== Done! ==="