#!/bin/bash
#
# tes3mp-easy-import-mods — Download and install plugins from a TES3MP server
#
# Replaces tes3mp-easy-client-update-mods.
#
# Algorithm:
#   1. Reads [import] section from tes3mp-easy-import.conf
#   2. Downloads mods.tar.gz from server HTTP endpoint
#   3. Removes old mods from Data Files
#   4. Extracts plugins/ from archive
#   5. Updates openmw.cfg with mod load order from requiredDataFiles.json
#   6. Checks for Proton compatdata data/ folder
#
# Configuration:
#   $(dirname "$0")/tes3mp-easy-import.conf
#
# Usage:
#   tes3mp-easy-import-mods
#
# Dependencies: bash, curl, tar

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/tes3mp-easy-import.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

err()  { echo -e "${RED}[ERROR]${NC} $*" >&2; }
ok()   { echo -e "${GREEN}[OK]${NC}   $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }

# --- INI parser for sections ---
parse_ini_section() {
    local file="$1"
    local section="$2"
    local prefix="$3"
    local in_section=0

    while IFS= read -r line; do
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" || "$line" =~ ^# ]] && continue

        if [[ "$line" =~ ^\[(.*)\]$ ]]; then
            if [ "${BASH_REMATCH[1]}" = "$section" ]; then
                in_section=1
            else
                in_section=0
            fi
            continue
        fi

        if [ "$in_section" -eq 1 ]; then
            local key="${line%%=*}"
            local value="${line#*=}"
            key="${key#"${key%%[![:space:]]*}"}"
            key="${key%"${key##*[![:space:]]}"}"
            value="${value#"${value%%[![:space:]]*}"}"
            value="${value%"${value##*[![:space:]]}"}"
            # Remove surrounding quotes if present
            case "$value" in
                \"*\") value="${value#\"}"; value="${value%\"}" ;;
                \'*\') value="${value#\'}"; value="${value%\'}" ;;
            esac
            printf -v "${prefix}${key}" "%s" "$value"
        fi
    done < "$file"
}

# --- Check config ---
if [ ! -f "$CONFIG_FILE" ]; then
    err "Config file not found: $CONFIG_FILE"
    echo ""
    echo "Edit the config template:"
    echo "  nano $CONFIG_FILE"
    exit 1
fi

# --- Parse config ---
parse_ini_section "$CONFIG_FILE" "import" "CFG_"

# --- Validate config ---
if [ -z "${CFG_CLIENT_DEFAULT:-}" ]; then
    err "CLIENT_DEFAULT is not set in [import] section of $CONFIG_FILE"
    exit 1
fi

if [ -z "${CFG_DATA_FILES:-}" ]; then
    err "DATA_FILES is not set in [import] section of $CONFIG_FILE"
    exit 1
fi

if [ -z "${CFG_OPENMW_CFG:-}" ]; then
    err "OPENMW_CFG is not set in [import] section of $CONFIG_FILE"
    exit 1
fi

HTTP_PORT=8085

# --- Check dependencies ---
for cmd in curl tar; do
    if ! command -v "$cmd" &>/dev/null; then
        err "'$cmd' not found. Install it and try again."
        exit 1
    fi
done

# --- Check paths exist ---
if [ ! -f "$CFG_CLIENT_DEFAULT" ]; then
    err "tes3mp-client-default.cfg not found: $CFG_CLIENT_DEFAULT"
    exit 1
fi

if [ ! -d "$CFG_DATA_FILES" ]; then
    err "Data Files directory not found: $CFG_DATA_FILES"
    exit 1
fi

# --- Extract destinationAddress from tes3mp-client-default.cfg ---
SERVER_HOST=""
while IFS='=' read -r key value; do
    key="${key// /}"
    if [ "${key,,}" = "destinationaddress" ]; then
        SERVER_HOST="${value//[$'\t\r ']/}"
        break
    fi
done < "$CFG_CLIENT_DEFAULT"

if [ -z "$SERVER_HOST" ]; then
    err "Could not find 'destinationAddress' in $CFG_CLIENT_DEFAULT"
    exit 1
fi

DOWNLOAD_URL="http://${SERVER_HOST}:${HTTP_PORT}/get-mods"

echo "=== TES3MP Client Sync ==="
echo "  Server:   $SERVER_HOST:$HTTP_PORT"
echo "  Data:     $CFG_DATA_FILES"
echo "  openmw:   $CFG_OPENMW_CFG"
echo ""

# --- Step 1: Download plugins ---
echo "[1/4] Downloading mods from $DOWNLOAD_URL ..."

TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

TMP_TGZ="$TMP_DIR/mods.tar.gz"

if ! curl -fsSL --max-time 30 "$DOWNLOAD_URL" -o "$TMP_TGZ"; then
    err "Failed to download plugins from $DOWNLOAD_URL"
    err "Make sure the server is running and the /get-mods endpoint is enabled."
    exit 1
fi

if [ ! -f "$TMP_TGZ" ] || [ ! -s "$TMP_TGZ" ]; then
    err "Downloaded file is empty"
    exit 1
fi

ok "Downloaded ($(du -h "$TMP_TGZ" | cut -f1))"

# --- Step 2: Remove old mods ---
echo ""
echo "[2/4] Removing old mods from Data Files..."

ORIGINAL_FILES=("Morrowind.esm" "Tribunal.esm" "Bloodmoon.esm")

removed=0
for pattern in "*.esp" "*.ESP" "*.esm" "*.ESM" \
               "*.omwaddon" "*.OMWADDON" \
               "*.omwscripts" "*.OMWSCRIPTS" \
               "*.omwgame" "*.OMWGAME"; do
    for file in "$CFG_DATA_FILES"/$pattern; do
        [ -f "$file" ] || continue
        basename="$(basename "$file")"

        skip=0
        for orig in "${ORIGINAL_FILES[@]}"; do
            if [ "$basename" = "$orig" ]; then
                skip=1
                break
            fi
        done

        if [ "$skip" -eq 1 ]; then
            echo "  - Preserved: $basename"
        else
            rm -f "$file"
            echo "  - Removed: $basename"
            ((removed++)) || true
        fi
    done
done

if [ "$removed" -eq 0 ]; then
    echo "  (no mods to remove)"
fi

# --- Step 3: Extract new mods (only plugins/ subdirectory) ---
echo ""
echo "[3/4] Extracting new mods to Data Files..."

# Extract the entire archive to a staging directory, then copy only plugins/
tar xzf "$TMP_TGZ" -C "$TMP_DIR"

if [ -d "$TMP_DIR/plugins" ] && [ -n "$(ls -A "$TMP_DIR/plugins" 2>/dev/null)" ]; then
    cp -r "$TMP_DIR/plugins"/* "$CFG_DATA_FILES/"
    ok "Extracted plugins from archive"
else
    warn "No plugins/ directory found in archive — nothing to extract"
fi

# Remove the downloaded archive
rm -f "$TMP_TGZ"
ok "Archive deleted"

# --- Step 4: Update openmw.cfg with mod load order from extracted archive ---
echo ""
echo "[4/4] Updating openmw.cfg with mod load order..."

REQ_JSON="$CFG_DATA_FILES/requiredDataFiles.json"

if [ ! -f "$REQ_JSON" ]; then
    err "requiredDataFiles.json not found in $CFG_DATA_FILES"
    err "The server must include it in the plugin archive."
    exit 1
fi

if [ ! -f "$CFG_OPENMW_CFG" ]; then
    warn "openmw.cfg not found at $CFG_OPENMW_CFG — creating"
    touch "$CFG_OPENMW_CFG"
fi

# Remove all existing content= entries
sed -i '/^content=/d' "$CFG_OPENMW_CFG"
# Remove any blank lines at the end
sed -i '$ { /^$/d; }' "$CFG_OPENMW_CFG"

echo "  Using load order from $REQ_JSON..."

if command -v python3 &>/dev/null; then
    python3 -c "
import json
with open('$REQ_JSON') as f:
    data = json.load(f)
for entry in data:
    for name in entry:
        print(f'content={name}')
" >> "$CFG_OPENMW_CFG"
else
    # Simple fallback: extract content= lines from the json
    grep -oP '"([^"]+\.(esp|esm|omwaddon|omwscripts|omwgame))"' "$REQ_JSON" | tr -d '"' | while read -r name; do
        echo "content=$name" >> "$CFG_OPENMW_CFG"
    done
fi

count=$(grep -c '^content=' "$CFG_OPENMW_CFG" 2>/dev/null || echo 0)
ok "openmw.cfg updated with $count entries in server load order"

echo ""
# --- Step 5: Check for Proton compatdata data/ folder ---
PROTON_DATA_DIR="$(dirname "$CFG_OPENMW_CFG")/data"
if [ -d "$PROTON_DATA_DIR" ]; then
    echo ""
    echo "⚠️  Proton prefix data/ folder detected"
    echo ""
    echo "OpenMW found a 'data/' folder next to openmw.cfg:"
    echo "  $PROTON_DATA_DIR"
    echo ""
    echo "This folder has higher priority than your Data Files directory."
    echo "If plugins in this folder differ from the server, TES3MP will"
    echo "reject the connection due to CRC mismatch."
    echo ""
    echo "This folder is not needed — your Data Files are already set"
    echo "correctly in the config."
    echo ""
    read -r -p "Remove this folder? [y/N]: " choice
    case "$choice" in
        y|Y|yes|Yes)
            rm -rf "$PROTON_DATA_DIR"
            ok "Removed: $PROTON_DATA_DIR"
            ;;
        *)
            warn "Skipped. If you encounter CRC issues, delete it manually:"
            warn "  rm -rf \"$PROTON_DATA_DIR\""
            ;;
    esac
fi

echo ""
echo "=== Done! ==="
echo "Plugins are installed and ready."