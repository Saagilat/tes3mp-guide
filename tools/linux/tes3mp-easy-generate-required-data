#!/bin/bash
#
# tes3mp-easy-generate-required-data — Generate requiredDataFiles.json for mod export
#
# Algorithm:
#   1. Reads [mods] section from tes3mp-easy-export.conf
#   2. Scans PLUGINS_DIR for mod files (.esp/.esm/.omwaddon/.omwscripts/.omwgame)
#   3. Computes CRC32 for each plugin via rhash
#   4. Generates requiredDataFiles.json in PLUGINS_DIR
#   5. Warns if file already exists and asks for confirmation
#
# Configuration:
#   $(dirname "$0")/tes3mp-easy-export.conf
#
# Usage:
#   tes3mp-easy-generate-required-data
#
# Dependencies: bash, rhash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/tes3mp-easy-export.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

err()  { echo -e "${RED}[ERROR]${NC} $*" >&2; }
ok()   { echo -e "${GREEN}[OK]${NC}   $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }
info() { echo -e "${BLUE}[INFO]${NC} $*"; }

# --- INI parser for sections ---
parse_ini_section() {
    local file="$1"
    local section="$2"
    local prefix="$3"
    local in_section=0

    while IFS= read -r line; do
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" || "$line" =~ ^# ]] && continue

        if [[ "$line" =~ ^\[(.*)\]$ ]]; then
            if [ "${BASH_REMATCH[1]}" = "$section" ]; then
                in_section=1
            else
                in_section=0
            fi
            continue
        fi

        if [ "$in_section" -eq 1 ]; then
            local key="${line%%=*}"
            local value="${line#*=}"
            key="${key#"${key%%[![:space:]]*}"}"
            key="${key%"${key##*[![:space:]]}"}"
            value="${value#"${value%%[![:space:]]*}"}"
            value="${value%"${value##*[![:space:]]}"}"
            # Remove surrounding quotes if present
            case "$value" in
                \"*\") value="${value#\"}"; value="${value%\"}" ;;
                \'*\') value="${value#\'}"; value="${value%\'}" ;;
            esac
            printf -v "${prefix}${key}" "%s" "$value"
        fi
    done < "$file"
}

# --- Check config ---
if [ ! -f "$CONFIG_FILE" ]; then
    err "Config file not found: $CONFIG_FILE"
    exit 1
fi

# --- Parse config ---
parse_ini_section "$CONFIG_FILE" "mods" "CFG_"

# --- Validate config ---
if [ -z "${CFG_PLUGINS_DIR:-}" ]; then
    err "PLUGINS_DIR is not set in [mods] section of $CONFIG_FILE"
    exit 1
fi

if [ ! -d "$CFG_PLUGINS_DIR" ]; then
    err "Plugins directory does not exist: $CFG_PLUGINS_DIR"
    exit 1
fi

# --- Check dependencies ---
if ! command -v rhash &>/dev/null; then
    err "'rhash' not found. Install it and try again."
    exit 1
fi

echo "=== TES3MP Generate requiredDataFiles.json ==="
echo "  Plugins dir:  $CFG_PLUGINS_DIR"
echo ""

ORIGINAL_FILES=("Morrowind.esm" "Tribunal.esm" "Bloodmoon.esm")

REQ_JSON="$CFG_PLUGINS_DIR/requiredDataFiles.json"

# --- Warn if file already exists ---
if [ -f "$REQ_JSON" ]; then
    warn "requiredDataFiles.json already exists in $CFG_PLUGINS_DIR"
    read -r -p "Overwrite? [y/N]: " choice
    case "$choice" in
        y|Y|yes|Yes) ;;
        *)
            info "Aborted."
            exit 0
            ;;
    esac
fi

# --- Scan plugins ---
echo "Scanning plugins in $CFG_PLUGINS_DIR ..."

# Collect plugin files
PLUGIN_FILES=()
for pattern in *.esp *.ESP *.esm *.ESM \
               *.omwaddon *.OMWADDON \
               *.omwscripts *.OMWSCRIPTS \
               *.omwgame *.OMWGAME; do
    for file in "$CFG_PLUGINS_DIR"/$pattern; do
        [ -f "$file" ] || continue
        basename="$(basename "$file")"

        # Skip original files
        skip=0
        for orig in "${ORIGINAL_FILES[@]}"; do
            if [ "${basename,,}" = "${orig,,}" ]; then
                skip=1
                break
            fi
        done
        [ "$skip" -eq 1 ] && continue

        PLUGIN_FILES+=("$file")
    done
done

# Sort by filename
IFS=$'\n' PLUGIN_FILES=($(sort <<<"${PLUGIN_FILES[*]}"))
unset IFS

echo "  Found ${#PLUGIN_FILES[@]} non-original plugin(s)"
echo ""

# --- Generate JSON ---
echo "Generating $REQ_JSON ..."

printf "[\n" > "$REQ_JSON"

# Add original master files with empty CRC
for orig in "${ORIGINAL_FILES[@]}"; do
    printf '  {\n    "%s": []\n  },\n' "$orig" >> "$REQ_JSON"
done

# Add each plugin with its CRC32
for filepath in "${PLUGIN_FILES[@]}"; do
    basename="$(basename "$filepath")"
    echo -n "  Computing CRC32 for $basename ... "
    crc=$(rhash --crc32 --simple "$filepath" | cut -d' ' -f1 | tr '[:lower:]' '[:upper:]')
    if [ -n "$crc" ]; then
        printf '  {\n    "%s": ["0x%s"]\n  },\n' "$basename" "$crc" >> "$REQ_JSON"
        echo "0x$crc"
    else
        printf '  {\n    "%s": []\n  },\n' "$basename" >> "$REQ_JSON"
        echo "(CRC32 unavailable)"
    fi
done

# Remove trailing comma from last entry and close JSON array
sed -i '$ s/,$//' "$REQ_JSON"
printf "]\n" >> "$REQ_JSON"

total=$(( ${#ORIGINAL_FILES[@]} + ${#PLUGIN_FILES[@]} ))
ok "Generated $REQ_JSON with $total entries"

echo ""
echo "=== Done! ==="
echo "Run 'tes3mp-easy-export-mods' to package and send to server."