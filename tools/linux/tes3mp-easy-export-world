#!/bin/bash
#
# tes3mp-easy-export-world — Package and export world data to a TES3MP server
#
# Algorithm:
#   1. Reads [world] section from tes3mp-easy-export.conf
#   2. Reads [export] section for SSH_HOST
#   3. Packages world via package.sh (source) → world.tar.gz
#   4. SCPs to server:/tes3mp-easy/import-world/
#   5. Runs import_world.sh on server via SSH
#   6. Cleans up local archive
#
# Configuration:
#   $(dirname "$0")/tes3mp-easy-export.conf
#
# Usage:
#   tes3mp-easy-export-world
#
# Dependencies: bash, tar, ssh, scp

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/tes3mp-easy-export.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

err()  { echo -e "${RED}[ERROR]${NC} $*" >&2; }
ok()   { echo -e "${GREEN}[OK]${NC}   $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }

# --- INI parser for sections ---
parse_ini_section() {
    local file="$1"
    local section="$2"
    local prefix="$3"
    local in_section=0

    while IFS= read -r line; do
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" || "$line" =~ ^# ]] && continue

        if [[ "$line" =~ ^\[(.*)\]$ ]]; then
            if [ "${BASH_REMATCH[1]}" = "$section" ]; then
                in_section=1
            else
                in_section=0
            fi
            continue
        fi

        if [ "$in_section" -eq 1 ]; then
            local key="${line%%=*}"
            local value="${line#*=}"
            key="${key#"${key%%[![:space:]]*}"}"
            key="${key%"${key##*[![:space:]]}"}"
            value="${value#"${value%%[![:space:]]*}"}"
            value="${value%"${value##*[![:space:]]}"}"
            printf -v "${prefix}${key}" "%s" "$value"
        fi
    done < "$file"
}

# --- Check config ---
if [ ! -f "$CONFIG_FILE" ]; then
    err "Config file not found: $CONFIG_FILE"
    exit 1
fi

# --- Parse config sections ---
parse_ini_section "$CONFIG_FILE" "export" "CFG_"
parse_ini_section "$CONFIG_FILE" "world" "CFG_"

# --- Validate config ---
if [ -z "${CFG_SSH_HOST:-}" ]; then
    err "SSH_HOST is not set in [export] section of $CONFIG_FILE"
    exit 1
fi

if [ -z "${CFG_WORLD_DIR:-}" ]; then
    err "WORLD_DIR is not set in [world] section of $CONFIG_FILE"
    exit 1
fi

if [ ! -d "$CFG_WORLD_DIR" ]; then
    err "World directory does not exist: $CFG_WORLD_DIR"
    exit 1
fi

# --- Check dependencies ---
for cmd in tar ssh scp; do
    if ! command -v "$cmd" &>/dev/null; then
        err "'$cmd' not found. Install it and try again."
        exit 1
    fi
done

echo "=== TES3MP Export World ==="
echo "  SSH host:            $CFG_SSH_HOST"
echo "  World dir:           $CFG_WORLD_DIR"
echo ""

# --- Step 1: Package world ---
echo "[1/4] Packaging world data..."

TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

OUTPUT_ARCHIVE="$TMP_DIR/world.tar.gz"

# Source package.sh and create archive
# The world archive expects player/ and cell/ subdirectories at the root
# The source directory should contain them directly
export PLAYER_DIR="$CFG_WORLD_DIR/player"
export CELL_DIR="$CFG_WORLD_DIR/cell"

source "$SCRIPT_DIR/../../server_setup/scripts/package.sh"

package_world "$OUTPUT_ARCHIVE"

if [ ! -f "$OUTPUT_ARCHIVE" ]; then
    err "Failed to create archive"
    exit 1
fi
ok "Archive created: $OUTPUT_ARCHIVE"

# --- Step 2: Transfer to server ---
echo ""
echo "[2/4] Transferring to server..."

ssh "$CFG_SSH_HOST" "mkdir -p /tes3mp-easy/import-world" || {
    err "Failed to create remote directory"
    exit 1
}

scp "$OUTPUT_ARCHIVE" "$CFG_SSH_HOST":/tes3mp-easy/import-world/world.tar.gz || {
    err "Failed to transfer archive to server"
    exit 1
}
ok "Archive transferred to $CFG_SSH_HOST:/tes3mp-easy/import-world/"

# --- Step 3: Run import_world.sh on server ---
echo ""
echo "[3/4] Running import_world.sh on server..."

ssh "$CFG_SSH_HOST" "cd /tes3mp-easy && bash scripts/import_world.sh" || {
    err "import_world.sh failed on server — check server logs"
    exit 1
}
ok "Server import completed"

# --- Step 4: Clean up local archive ---
echo ""
echo "[4/4] Cleaning up..."
rm -f "$OUTPUT_ARCHIVE"
ok "Local archive cleaned up"

echo ""
echo "=== Done! ==="