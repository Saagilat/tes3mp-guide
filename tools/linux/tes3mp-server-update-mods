#!/bin/bash
#
# tes3mp-server-update — Sync server plugins and scripts to a remote TES3MP server
#
# This script reads the configuration from tes3mp-server-update.conf (next to this script),
# syncs the local plugins and server scripts to the server, and runs update_mods.sh.
#
# Configuration:
#   $(dirname "$0")/tes3mp-server-update.conf
#
# Usage:
#   tes3mp-server-update
#
# Dependencies: bash, rsync, ssh

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/tes3mp-server-update.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

err()  { echo -e "${RED}[ERROR]${NC} $*" >&2; }
ok()   { echo -e "${GREEN}[OK]${NC}   $*"; }

# --- Check config ---
if [ ! -f "$CONFIG_FILE" ]; then
    err "Config file not found: $CONFIG_FILE"
    echo ""
    echo "Edit the config template:"
    echo "  nano $CONFIG_FILE"
    exit 1
fi

# --- Source config ---
source "$CONFIG_FILE"

# --- Validate config ---
if [ -z "${SSH_HOST:-}" ]; then
    err "SSH_HOST is not set in $CONFIG_FILE"
    exit 1
fi

if [ -z "${PLUGINS_DIR:-}" ]; then
    err "PLUGINS_DIR is not set in $CONFIG_FILE"
    exit 1
fi

if [ ! -d "$PLUGINS_DIR" ]; then
    err "Plugins directory does not exist: $PLUGINS_DIR"
    exit 1
fi

if [ -z "${SERVER_SCRIPTS_DIR:-}" ]; then
    err "SERVER_SCRIPTS_DIR is not set in $CONFIG_FILE"
    exit 1
fi

if [ ! -d "$SERVER_SCRIPTS_DIR" ]; then
    err "Server scripts directory does not exist: $SERVER_SCRIPTS_DIR"
    exit 1
fi

if [ -z "${CLIENT_SCRIPTS_DIR:-}" ]; then
    err "CLIENT_SCRIPTS_DIR is not set in $CONFIG_FILE"
    exit 1
fi

if [ ! -d "$CLIENT_SCRIPTS_DIR" ]; then
    err "Client scripts directory does not exist: $CLIENT_SCRIPTS_DIR"
    exit 1
fi

# --- Check dependencies ---
for cmd in rsync ssh; do
    if ! command -v "$cmd" &>/dev/null; then
        err "'$cmd' not found. Install it and try again."
        exit 1
    fi
done

echo "=== TES3MP Server Sync ==="
echo "  SSH host:            $SSH_HOST"
echo "  Plugins dir:         $PLUGINS_DIR"
echo "  Server scripts:      $SERVER_SCRIPTS_DIR"
echo "  Client scripts:      $CLIENT_SCRIPTS_DIR"
echo ""

# --- Step 1: Sync plugins ---
echo "[1/4] Syncing plugins to server..."
rsync -avz --delete "$PLUGINS_DIR"/ "$SSH_HOST":/opt/tes3mp/plugins/
ok "Plugins sync complete"

echo ""
# --- Step 2: Sync server scripts ---
echo "[2/4] Syncing server scripts to server..."
rsync -avz --delete "$SERVER_SCRIPTS_DIR"/ "$SSH_HOST":/opt/tes3mp/server-scripts/
ok "Server scripts sync complete"

echo ""
# --- Step 3: Sync client scripts ---
echo "[3/4] Syncing client scripts to server..."
rsync -avz --delete "$CLIENT_SCRIPTS_DIR"/ "$SSH_HOST":/opt/tes3mp/client-scripts/
ok "Client scripts sync complete"

echo ""
echo "[4/4] Running update_mods.sh on server..."
ssh "$SSH_HOST" "cd /opt/tes3mp && bash update_mods.sh"

echo ""
echo "=== Done! ==="