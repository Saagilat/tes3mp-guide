#!/bin/bash
#
# tes3mp-client-sync — Download and install plugins from a TES3MP server
#
# This script reads the configuration from tes3mp-client-sync.conf (next to this script),
# downloads the latest plugin pack from the server, replaces old mods in Data Files,
# and updates openmw.cfg with the installed mods.
#
# Configuration:
#   $(dirname "$0")/tes3mp-client-sync.conf
#
# Usage:
#   tes3mp-client-sync
#
# Dependencies: bash, curl, unzip

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/tes3mp-client-sync.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

err()  { echo -e "${RED}[ERROR]${NC} $*" >&2; }
ok()   { echo -e "${GREEN}[OK]${NC}   $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }

# --- Check config ---
if [ ! -f "$CONFIG_FILE" ]; then
    err "Config file not found: $CONFIG_FILE"
    echo ""
    echo "Edit the config template:"
    echo "  nano $CONFIG_FILE"
    exit 1
fi

# --- Parse config (manual, to handle spaces in values properly) ---
while IFS='=' read -r key value; do
    # Trim leading/trailing whitespace from key
    key="${key#"${key%%[![:space:]]*}"}"
    key="${key%"${key##*[![:space:]]}"}"

    # Skip comments and empty lines
    case "$key" in
        \#*|'') continue ;;
    esac

    # Trim leading/trailing whitespace from value
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"

    # Remove surrounding quotes if present
    case "$value" in
        \"*\") value="${value#\"}"; value="${value%\"}" ;;
        \'*\') value="${value#\'}"; value="${value%\'}" ;;
    esac

    printf -v "$key" "%s" "$value"
done < "$CONFIG_FILE"

# --- Validate config ---
if [ -z "${CLIENT_DEFAULT:-}" ]; then
    err "CLIENT_DEFAULT is not set in $CONFIG_FILE"
    exit 1
fi

if [ -z "${DATA_FILES:-}" ]; then
    err "DATA_FILES is not set in $CONFIG_FILE"
    exit 1
fi

if [ -z "${OPENMW_CFG:-}" ]; then
    err "OPENMW_CFG is not set in $CONFIG_FILE"
    exit 1
fi

HTTP_PORT=8085

# --- Check dependencies ---
for cmd in curl unzip; do
    if ! command -v "$cmd" &>/dev/null; then
        err "'$cmd' not found. Install it and try again."
        exit 1
    fi
done

# --- Check paths exist ---
if [ ! -f "$CLIENT_DEFAULT" ]; then
    err "tes3mp-client-default.cfg not found: $CLIENT_DEFAULT"
    exit 1
fi

if [ ! -d "$DATA_FILES" ]; then
    err "Data Files directory not found: $DATA_FILES"
    exit 1
fi

# --- Extract destinationAddress from tes3mp-client-default.cfg ---
SERVER_HOST=""
while IFS='=' read -r key value; do
    key="${key// /}"
    if [ "${key,,}" = "destinationaddress" ]; then
        SERVER_HOST="${value//[$'\t\r ']/}"
        break
    fi
done < "$CLIENT_DEFAULT"

if [ -z "$SERVER_HOST" ]; then
    err "Could not find 'destinationAddress' in $CLIENT_DEFAULT"
    exit 1
fi

DOWNLOAD_URL="http://${SERVER_HOST}:${HTTP_PORT}/get-plugins"
REQ_DATA_URL="http://${SERVER_HOST}:${HTTP_PORT}/get-required-data"

echo "=== TES3MP Client Sync ==="
echo "  Server:   $SERVER_HOST:$HTTP_PORT"
echo "  Data:     $DATA_FILES"
echo "  openmw:   $OPENMW_CFG"
echo ""

# --- Step 1: Download plugins ---
echo "[1/4] Downloading plugins from $DOWNLOAD_URL ..."

TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

TMP_ZIP="$TMP_DIR/plugins.zip"

if ! curl -fsSL --max-time 30 "$DOWNLOAD_URL" -o "$TMP_ZIP"; then
    err "Failed to download plugins from $DOWNLOAD_URL"
    err "Make sure the server is running and the /get-plugins endpoint is enabled."
    exit 1
fi

if [ ! -f "$TMP_ZIP" ] || [ ! -s "$TMP_ZIP" ]; then
    err "Downloaded file is empty"
    exit 1
fi

ok "Downloaded ($(du -h "$TMP_ZIP" | cut -f1))"

# --- Step 2: Remove old mods ---
echo ""
echo "[2/4] Removing old mods from Data Files..."

ORIGINAL_FILES=("Morrowind.esm" "Tribunal.esm" "Bloodmoon.esm")

removed=0
for pattern in "*.esp" "*.ESP" "*.esm" "*.ESM" \
               "*.omwaddon" "*.OMWADDON" \
               "*.omwscripts" "*.OMWSCRIPTS" \
               "*.omwgame" "*.OMWGAME"; do
    for file in "$DATA_FILES"/$pattern; do
        [ -f "$file" ] || continue
        basename="$(basename "$file")"

        skip=0
        for orig in "${ORIGINAL_FILES[@]}"; do
            if [ "$basename" = "$orig" ]; then
                skip=1
                break
            fi
        done

        if [ "$skip" -eq 1 ]; then
            echo "  - Preserved: $basename"
        else
            rm -f "$file"
            echo "  - Removed: $basename"
            ((removed++)) || true
        fi
    done
done

if [ "$removed" -eq 0 ]; then
    echo "  (no mods to remove)"
fi

# --- Step 3: Extract new mods ---
echo ""
echo "[3/4] Extracting new mods to Data Files..."

unzip -o -q "$TMP_ZIP" -d "$DATA_FILES"

ok "Extracted"

# Remove the downloaded archive
rm -f "$TMP_ZIP"
ok "Archive deleted"

# --- Step 4: Update openmw.cfg with mod load order from server ---
echo ""
echo "[4/4] Updating openmw.cfg with mod load order..."

if [ ! -f "$OPENMW_CFG" ]; then
    warn "openmw.cfg not found at $OPENMW_CFG — creating"
    touch "$OPENMW_CFG"
fi

# Remove all existing content= entries
sed -i '/^content=/d' "$OPENMW_CFG"
# Remove any blank lines at the end
sed -i '$ { /^$/d; }' "$OPENMW_CFG"

# Download requiredDataFiles.json from server for correct load order
TMP_REQ="$TMP_DIR/requiredDataFiles.json"
echo ""
if curl -fsSL --max-time 10 "$REQ_DATA_URL" -o "$TMP_REQ" 2>/dev/null && [ -s "$TMP_REQ" ]; then
    echo "  Using load order from server..."

    # Parse JSON via rhash-based approach — simple lines
    # Actually use python3 if available, otherwise fallback to simple parsing
    if command -v python3 &>/dev/null; then
        python3 -c "
import json
with open('$TMP_REQ') as f:
    data = json.load(f)
for entry in data:
    for name in entry:
        print(f'content={name}')
" >> "$OPENMW_CFG"
    else
        # Simple fallback: extract content= lines from the json
        grep -oP '"([^"]+\.(esp|esm|omwaddon|omwscripts|omwgame))"' "$TMP_REQ" | tr -d '"' | while read -r name; do
            echo "content=$name" >> "$OPENMW_CFG"
        done
    fi

    count=$(grep -c '^content=' "$OPENMW_CFG" 2>/dev/null || echo 0)
    ok "openmw.cfg updated with $count entries in server load order"
else
    warn "Could not fetch requiredDataFiles.json — using files from Data Files in alphabetical order"
    for pattern in "*.esp" "*.ESP" "*.esm" "*.ESM" \
                   "*.omwaddon" "*.OMWADDON" \
                   "*.omwscripts" "*.OMWSCRIPTS" \
                   "*.omwgame" "*.OMWGAME"; do
        for file in "$DATA_FILES"/$pattern; do
            [ -f "$file" ] || continue
            basename="$(basename "$file")"
            echo "content=$basename" >> "$OPENMW_CFG"
            echo "  - Added to openmw.cfg: $basename"
        done
    done
    ok "openmw.cfg updated with files found in Data Files"
fi

echo ""
echo "=== Done! ==="
echo "Plugins are installed and ready."
echo "Run tes3mp-client-sync again to update when the server pack changes."