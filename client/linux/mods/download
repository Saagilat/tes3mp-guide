#!/bin/bash
#
# tes3mp-download-mods — Download and install mods from a TES3MP server
#
# This script reads the client configuration from ~/.config/tes3mp/client.conf,
# downloads the latest mod pack from the server, replaces old mods in Data Files,
# and ensures openmw.cfg includes the mods config.
#
# Configuration (~/.config/tes3mp/client.conf):
# Copy from: https://raw.githubusercontent.com/Saagilat/tes3mp-easy-setup/master/tools/linux/player/client.conf
#
# The mod archive is downloaded from port 8085 (default HTTP endpoint port
# for the nginx container serving the mod pack).
#
# Usage:
#   tes3mp-download-mods
#
# Dependencies: bash, curl, unzip

set -euo pipefail

CONFIG_FILE="$HOME/.config/tes3mp/client.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

err()  { echo -e "${RED}[ERROR]${NC} $*" >&2; }
ok()   { echo -e "${GREEN}[OK]${NC}   $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }

# --- Check config ---
if [ ! -f "$CONFIG_FILE" ]; then
    err "Config file not found: $CONFIG_FILE"
    echo ""
    echo "Download the template:"
    echo "  mkdir -p ~/.config/tes3mp"
    echo "  wget -O $CONFIG_FILE \\"
    echo "    https://raw.githubusercontent.com/Saagilat/tes3mp-easy-setup/master/tools/linux/player/client.conf"
    echo ""
    echo "Then edit it: nano $CONFIG_FILE"
    exit 1
fi

# --- Parse config (manual, to handle spaces in values properly) ---
while IFS='=' read -r key value; do
    # Trim leading/trailing whitespace from key
    key="${key#"${key%%[![:space:]]*}"}"
    key="${key%"${key##*[![:space:]]}"}"

    # Skip comments and empty lines
    case "$key" in
        \#*|'') continue ;;
    esac

    # Trim leading/trailing whitespace from value
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"

    # Remove surrounding quotes if present
    case "$value" in
        \"*\") value="${value#\"}"; value="${value%\"}" ;;
        \'*\') value="${value#\'}"; value="${value%\'}" ;;
    esac

    printf -v "$key" "%s" "$value"
done < "$CONFIG_FILE"

# --- Validate config ---
if [ -z "${CLIENT_DEFAULT:-}" ]; then
    err "CLIENT_DEFAULT is not set in $CONFIG_FILE"
    exit 1
fi

if [ -z "${DATA_FILES:-}" ]; then
    err "DATA_FILES is not set in $CONFIG_FILE"
    exit 1
fi

if [ -z "${OPENMW_CFG:-}" ]; then
    err "OPENMW_CFG is not set in $CONFIG_FILE"
    exit 1
fi

HTTP_PORT=8085

# --- Check dependencies ---
for cmd in curl unzip; do
    if ! command -v "$cmd" &>/dev/null; then
        err "'$cmd' not found. Install it and try again."
        exit 1
    fi
done

# --- Check paths exist ---
if [ ! -f "$CLIENT_DEFAULT" ]; then
    err "tes3mp-client-default.cfg not found: $CLIENT_DEFAULT"
    exit 1
fi

if [ ! -d "$DATA_FILES" ]; then
    err "Data Files directory not found: $DATA_FILES"
    exit 1
fi

# --- Extract hostname from tes3mp-client-default.cfg ---
SERVER_HOST=""
while IFS='=' read -r key value; do
    key="${key// /}"
    if [ "${key,,}" = "hostname" ]; then
        SERVER_HOST="${value/ /}"
        break
    fi
done < "$CLIENT_DEFAULT"

if [ -z "$SERVER_HOST" ]; then
    err "Could not find 'hostname' in $CLIENT_DEFAULT"
    exit 1
fi

DOWNLOAD_URL="http://${SERVER_HOST}:${HTTP_PORT}/get-mods"

echo "=== TES3MP Mod Download ==="
echo "  Server:   $SERVER_HOST:$HTTP_PORT"
echo "  Data:     $DATA_FILES"
echo "  openmw:   $OPENMW_CFG"
echo ""

# --- Step 1: Download mods ---
echo "[1/4] Downloading mods from $DOWNLOAD_URL ..."

TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

TMP_ZIP="$TMP_DIR/mods.zip"

if ! curl -fsSL --max-time 30 "$DOWNLOAD_URL" -o "$TMP_ZIP"; then
    err "Failed to download mods from $DOWNLOAD_URL"
    err "Make sure the server is running and the /get-mods endpoint is enabled."
    exit 1
fi

if [ ! -f "$TMP_ZIP" ] || [ ! -s "$TMP_ZIP" ]; then
    err "Downloaded file is empty"
    exit 1
fi

ok "Downloaded ($(du -h "$TMP_ZIP" | cut -f1))"

# --- Step 2: Remove old mods ---
echo ""
echo "[2/4] Removing old mods from Data Files..."

ORIGINAL_FILES=("Morrowind.esm" "Tribunal.esm" "Bloodmoon.esm")

removed=0
for pattern in "*.esp" "*.ESP" "*.esm" "*.ESM" \
               "*.omwaddon" "*.OMWADDON" \
               "*.omwscripts" "*.OMWSCRIPTS" \
               "*.omwgame" "*.OMWGAME"; do
    for file in "$DATA_FILES"/$pattern; do
        [ -f "$file" ] || continue
        basename="$(basename "$file")"

        skip=0
        for orig in "${ORIGINAL_FILES[@]}"; do
            if [ "$basename" = "$orig" ]; then
                skip=1
                break
            fi
        done

        if [ "$skip" -eq 1 ]; then
            echo "  - Preserved: $basename"
        else
            rm -f "$file"
            echo "  - Removed: $basename"
            ((removed++)) || true
        fi
    done
done

if [ "$removed" -eq 0 ]; then
    echo "  (no mods to remove)"
fi

# --- Step 3: Extract new mods ---
echo ""
echo "[3/4] Extracting new mods to Data Files..."

unzip -o -q "$TMP_ZIP" -d "$DATA_FILES"

ok "Extracted"

# Remove the downloaded archive
rm -f "$TMP_ZIP"
ok "Archive deleted"

# --- Step 4: Ensure openmw.cfg includes mods.cfg ---
echo ""
echo "[4/4] Checking openmw.cfg..."
INCLUDE_LINE="include = mods.cfg"

if [ ! -f "$OPENMW_CFG" ]; then
    warn "openmw.cfg not found at $OPENMW_CFG — creating"
    echo "$INCLUDE_LINE" > "$OPENMW_CFG"
    ok "Created $OPENMW_CFG with $INCLUDE_LINE"
else
    if grep -Fxq "$INCLUDE_LINE" "$OPENMW_CFG" 2>/dev/null; then
        ok "openmw.cfg already includes mods.cfg"
    else
        echo "" >> "$OPENMW_CFG"
        echo "$INCLUDE_LINE" >> "$OPENMW_CFG"
        ok "Added '$INCLUDE_LINE' to openmw.cfg"
    fi
fi

echo ""
echo "=== Done! ==="
echo "Mods are installed and ready."
echo "Run tes3mp-download-mods again to update mods when the server pack changes."